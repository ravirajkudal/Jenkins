Phase 3: The Advanced Jenkinsfile
Create a file named Jenkinsfile in the root of your project, commit it, and push it to GitHub. This pipeline covers all your requested syntax.
Groovy
pipeline {
    agent any
    
    // Tools required for the build
    tools {
        nodejs 'Node18' // Matches the name configured in Manage Jenkins -> Tools
    }

    // Parameters to trigger manual builds with options
    parameters {
        choice(name: 'DEPLOY_ENV', choices: ['dev', 'staging', 'prod'], description: 'Select deployment environment')
        booleanParam(name: 'RUN_TESTS', defaultValue: true, description: 'Uncheck to skip tests')
    }

    // Global Environment variables
    environment {
        APP_NAME = "MySampleApp"
        // Dummy credentials mapping
        DEPLOY_TOKEN = credentials('dummy-deploy-token') 
    }

    stages {
        stage('Build') {
            steps {
                echo "Building ${APP_NAME} for ${params.DEPLOY_ENV} environment..."
                sh 'npm install'
            }
        }

        stage('Test') {
            // 'when' condition based on the parameter
            when {
                expression { params.RUN_TESTS == true }
            }
            // Parallel execution to speed up pipelines
            parallel {
                stage('Unit Tests') {
                    steps {
                        echo "Running Unit Tests..."
                        sh 'npm run test:unit'
                    }
                }
                stage('Integration Tests') {
                    steps {
                        echo "Running Integration Tests..."
                        sh 'npm run test:integration'
                    }
                }
            }
        }

        stage('Deploy') {
            // 'when' condition based on branch and parameter
            when {
                branch 'main'
                environment name: 'DEPLOY_ENV', value: 'prod'
            }
            steps {
                echo "Deploying to Production securely..."
                // Masking credentials in logs while using them
                sh '''
                    echo "Connecting to server using token: ${DEPLOY_TOKEN}"
                    echo "Starting node server..."
                    node app.js > app.log 2>&1 &
                '''
            }
        }
    }

    // Post-build actions based on pipeline status
    post {
        always {
            echo "Pipeline execution finished. Cleaning up workspace..."
            cleanWs() // Cleans the workspace
        }
        success {
            echo "SUCCESS: The pipeline ran flawlessly!"
        }
        failure {
            echo "FAILURE: Something went wrong. Check the logs."
        }
    }
}


Phase 4: Jenkins UI Configuration & Webhook

1. Create the Dummy Credentials Before creating the job, Jenkins needs the credential referenced in the Jenkinsfile.
Go to Manage Jenkins -> Credentials -> System -> Global credentials.
Click Add Credentials.
Kind: Secret text.
Secret: super-secret-token-123.
ID: dummy-deploy-token (Must match the ID in the Jenkinsfile exactly).
Save.

2. Create the Pipeline Job
Click New Item on the Jenkins dashboard.
Name it Advanced-Node-Pipeline, select Pipeline, and click OK.
Under the General tab, check This project is parameterized (Jenkins will populate this automatically after the first run, but it's good to note).
Under Build Triggers, check GitHub hook trigger for GITScm polling.
Scroll down to the Pipeline section:
Definition: Pipeline script from SCM
SCM: Git
Repository URL: https://github.com/YOUR_USER/jenkins-advanced-pipeline.git
Branch Specifier: */main
Script Path: Jenkinsfile
Save.

3. Configure GitHub Webhook
Go to your GitHub repository -> Settings -> Webhooks -> Add webhook.
sudo snap install ngrok
Create ngrok account
Go here:
 https://dashboard.ngrok.com/signup
Get your authtoken
After login, go to:
  https://dashboard.ngrok.com/get-started/your-authtoken
Payload URL: http://<YOUR_JENKINS_PUBLIC_IP_OR_NGROK>:8080/github-webhook/ (Note: If Jenkins is on localhost, GitHub can't reach it. You must use a tool like ngrok (ngrok http 8080) to expose it to the internet temporarily).
Important:
The URL MUST end with a trailing slash (/).
Without the final slash, some Jenkins versions may return a 404 error and the webhook will fail.
Content type: application/json.
Events: Send me everything (or just push events).
Save.

Phase 5: Execution & Observation
Trigger Manually: Click Build with Parameters in the Jenkins UI. Change DEPLOY_ENV to prod to see the deploy stage run, or uncheck RUN_TESTS to see the test stage skipped.
Trigger via Webhook: Make a change to app.js, commit, and push to GitHub. Watch Jenkins automatically start a new build.
Observe: Click on the Build number in the history, then click Console Output to read the logs. You will see the ${DEPLOY_TOKEN} is masked with ** in the logs.This prevents sensitive credentials from being exposed in build logs.
